# Database
DATABASE_URL=postgresql+asyncpg://ojas:ojas_dev@localhost:5432/ojas_demo

# Deepgram — Speech-to-Text (auto-detects Indian languages)
# Get key at: https://console.deepgram.com
DEEPGRAM_API_KEY=your_deepgram_api_key_here

# OpenAI — GPT-4o for structuring transcripts AND prescription OCR (no Google Vision needed)
# Get key at: https://platform.openai.com/api-keys
OPENAI_API_KEY=your_openai_api_key_here

# JWT secret — any long random string
SECRET_KEY=change-me-to-something-random

# Local folder where prescription images are saved
UPLOADS_DIR=./uploads

# OpenAI model
OPENAI_MODEL=gpt-4o
