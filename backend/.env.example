# Database (separate DB from apps/api — run: createdb ojas_demo)
DATABASE_URL=postgresql+asyncpg://ojas:ojas_dev@localhost:5432/ojas_demo

# Deepgram — Speech-to-Text (auto-detects language including Indian languages)
# Get key at: https://console.deepgram.com
DEEPGRAM_API_KEY=your_deepgram_api_key_here

# Google Cloud Vision — OCR for prescription images
# Create API key at: https://console.cloud.google.com → APIs → Cloud Vision API
GOOGLE_VISION_API_KEY=your_google_vision_api_key_here

# OpenAI — GPT-4o for structuring transcripts and prescriptions
# Get key at: https://platform.openai.com/api-keys
OPENAI_API_KEY=your_openai_api_key_here

# Local folder where prescription images are saved
UPLOADS_DIR=./uploads

# OpenAI model
OPENAI_MODEL=gpt-4o
