# ── Database ──────────────────────────────────────────────────────────────────
DATABASE_URL=postgresql+asyncpg://ojas:ojas_dev@localhost:5432/ojas

# ── Redis ─────────────────────────────────────────────────────────────────────
REDIS_URL=redis://localhost:6379/0

# ── Object Storage (MinIO locally, S3/R2 in prod) ────────────────────────────
S3_ENDPOINT_URL=http://localhost:9000
S3_ACCESS_KEY=minioadmin
S3_SECRET_KEY=minioadmin
S3_BUCKET=ojas-artifacts

# ── Speech-to-Text ────────────────────────────────────────────────────────────
# Options: "local" (faster-whisper) or "stub" (returns empty transcript)
STT_PROVIDER=local
# STT_MODEL_SIZE=small
# STT_COMPUTE_TYPE=int8
# STT_DEVICE=cpu
# STT_CPU_THREADS=4
# STT_LANGUAGE=en

# ── Application ───────────────────────────────────────────────────────────────
ENVIRONMENT=dev
LOG_LEVEL=DEBUG
JWT_SECRET=change-me-in-production-use-a-long-random-string

# ── AI Extension (uncomment when you add AI modules) ─────────────────────────
# LLM_BASE_URL=http://localhost:8001/v1
# LLM_MODEL=qwen2.5-7b
# EMBEDDING_MODEL=BAAI/bge-m3
# EMBEDDING_DIM=1024
