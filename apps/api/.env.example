# Database
DATABASE_URL=postgresql+asyncpg://ojas:ojas_dev@localhost:5432/ojas

# Redis
REDIS_URL=redis://localhost:6379/0

# Object Storage (MinIO locally, S3/R2 in prod)
S3_ENDPOINT_URL=http://localhost:9000
S3_ACCESS_KEY=minioadmin
S3_SECRET_KEY=minioadmin
S3_BUCKET=ojas-artifacts

# STT Configuration
STT_PROVIDER=local
STT_MODEL_SIZE=tiny.en

# Environment
ENVIRONMENT=dev
LOG_LEVEL=DEBUG
JWT_SECRET=change-me-in-production-use-a-long-random-string
UPLOADS_DIR=./uploads

# AI Services - Fill these with your actual API keys
OPENAI_API_KEY=your_openai_api_key_here
OPENAI_MODEL=gpt-4o

DEEPGRAM_API_KEY=your_deepgram_api_key_here

GEMINI_API_KEY=your_gemini_api_key_here
GEMINI_BASE_URL=https://generativelanguage.googleapis.com/v1beta/openai/
GEMINI_MODEL_FLASH=gemini-flash-latest
GEMINI_MODEL_PRO=gemini-flash-latest

GROQ_API_KEY=your_groq_api_key_here
GROQ_MODEL=llama-3.3-70b-versatile
